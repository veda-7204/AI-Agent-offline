pipeline {
    agent any

    environment {
        OLLAMA_URL     = 'http://localhost:11434'
        REPORTS_DIR    = 'reports'
        WATCH_EXTS     = '.py .js .ts .java .cpp .c .go .rb .php'
        DOCKER_TIMEOUT = '30'
    }

    triggers {
        githubPush()
    }

    stages {

        // -------------------------------------------------------
        // STAGE 1 — Checkout
        // Pull the exact commit that triggered this build
        // -------------------------------------------------------
        stage('Checkout') {
            steps {
                echo "Checking out commit: ${env.GIT_COMMIT}"
                checkout scm
                echo "Workspace ready at: ${env.WORKSPACE}"
            }
        }

        // -------------------------------------------------------
        // STAGE 2 — Setup
        // Install Python dependencies and verify Ollama is running
        // -------------------------------------------------------
        stage('Setup') {
            steps {
                echo "Installing Python dependencies..."
                sh 'pip3 install -r requirements.txt --quiet'

                echo "Checking Ollama is running..."
                script {
                    def ollamaCheck = sh(
                        script: 'curl -s http://localhost:11434/api/tags',
                        returnStatus: true
                    )
                    if (ollamaCheck != 0) {
                        error("Ollama is not running. Start it with: ollama serve")
                    }
                    echo "Ollama is up and running."
                }
            }
        }

        // -------------------------------------------------------
        // STAGE 3 — Detect changes
        // Use git diff to find what files changed in this push
        // -------------------------------------------------------
        stage('Detect Changes') {
            steps {
                script {
                    echo "Detecting changed files..."

                    def changedFiles = sh(
                        script: 'git diff --name-only HEAD~1 HEAD',
                        returnStdout: true
                    ).trim()

                    if (!changedFiles) {
                        echo "No files changed. Skipping review."
                        currentBuild.result = 'SUCCESS'
                        return
                    }

                    echo "Changed files:\n${changedFiles}"

                    def supportedExts = env.WATCH_EXTS.split(' ')
                    def codeFiles = changedFiles.split('\n').findAll { file ->
                        supportedExts.any { ext -> file.trim().endsWith(ext) }
                    }

                    if (codeFiles.isEmpty()) {
                        echo "No supported code files changed. Skipping review."
                        currentBuild.result = 'SUCCESS'
                        return
                    }

                    echo "Code files to review: ${codeFiles}"
                    env.CHANGED_CODE_FILES = codeFiles.join(',')
                }
            }
        }

        // -------------------------------------------------------
        // STAGE 4 — AI Review
        // Send changed files to CodeLlama via Ollama
        // -------------------------------------------------------
        stage('AI Review') {
            when {
                expression { env.CHANGED_CODE_FILES != null && env.CHANGED_CODE_FILES != '' }
            }
            steps {
                script {
                    echo "Running AI code review on: ${env.CHANGED_CODE_FILES}"

                    def reviewResult = sh(
                        script: "python3 jenkins_agent.py --files '${env.CHANGED_CODE_FILES}' --commit '${env.GIT_COMMIT}' --branch '${env.BRANCH_NAME}'",
                        returnStatus: true
                    )

                    if (reviewResult == 1) {
                        echo "AI review flagged critical issues. Marking build UNSTABLE."
                        currentBuild.result = 'UNSTABLE'
                    } else if (reviewResult == 2) {
                        error("AI review agent failed to run. Check Ollama is running.")
                    } else {
                        echo "AI review complete. No critical issues found."
                    }
                }
            }
        }

        // -------------------------------------------------------
        // STAGE 5 — Run Code in Docker Sandbox
        // Safely execute changed files and capture output
        // -------------------------------------------------------
        stage('Run Code (Sandbox)') {
            when {
                expression { env.CHANGED_CODE_FILES != null && env.CHANGED_CODE_FILES != '' }
            }
            steps {
                script {
                    def files = env.CHANGED_CODE_FILES.split(',')

                    files.each { filePath ->
                        filePath = filePath.trim()
                        def ext = filePath.tokenize('.').last()
                        def dockerImage = getDockerImage(ext)

                        if (dockerImage == null) {
                            echo "No Docker image for .${ext} — skipping execution."
                            return
                        }

                        echo "Running ${filePath} in Docker (${dockerImage})..."

                        sh """
                            mkdir -p reports
                            docker run --rm \
                                --network none \
                                --memory 256m \
                                --cpus 0.5 \
                                -v "${env.WORKSPACE}:/app" \
                                --workdir /app \
                                ${dockerImage} \
                                timeout ${env.DOCKER_TIMEOUT} python3 ${filePath} \
                                > reports/execution_output.txt 2>&1 || true
                        """

                        echo "Execution complete. Output saved to reports/execution_output.txt"
                    }
                }
            }
        }

        // -------------------------------------------------------
        // STAGE 6 — Publish Report
        // Archive the report as a Jenkins build artifact
        // -------------------------------------------------------
        stage('Publish Report') {
            steps {
                script {
                    echo "Archiving review reports..."
                    sh 'mkdir -p reports'
                    archiveArtifacts artifacts: 'reports/*.md', allowEmptyArchive: true
                    archiveArtifacts artifacts: 'reports/*.txt', allowEmptyArchive: true

                    def reportFiles = findFiles(glob: 'reports/*.md')
                    if (reportFiles.length > 0) {
                        echo "Reports generated:"
                        reportFiles.each { f -> echo "  - ${f.name}" }
                    }
                }
            }
        }
    }

    // -------------------------------------------------------
    // POST — result notifications
    // -------------------------------------------------------
    post {
        success {
            echo """
            ============================================
             BUILD PASSED
             AI review found no critical issues.
             Commit : ${env.GIT_COMMIT}
             Branch : ${env.BRANCH_NAME}
            ============================================
            """
        }
        unstable {
            echo """
            ============================================
             BUILD UNSTABLE
             AI review flagged issues in your code.
             Check the Artifacts tab for the full report.
             Commit : ${env.GIT_COMMIT}
             Branch : ${env.BRANCH_NAME}
            ============================================
            """
        }
        failure {
            echo """
            ============================================
             BUILD FAILED
             Pipeline could not complete.
             Check console output for the error.
             Commit : ${env.GIT_COMMIT}
             Branch : ${env.BRANCH_NAME}
            ============================================
            """
        }
        always {
            echo "Pipeline finished. Check the Artifacts tab for the review report."
        }
    }
}

// Helper — map file extension to Docker image
def getDockerImage(String ext) {
    def imageMap = [
        'py'   : 'python:3.11-slim',
        'js'   : 'node:18-slim',
        'ts'   : 'node:18-slim',
        'java' : 'openjdk:17-slim',
        'go'   : 'golang:1.21-alpine',
        'rb'   : 'ruby:3.2-slim',
        'php'  : 'php:8.2-cli'
    ]
    return imageMap[ext]
}
