# Dockerfile.jenkins
# --------------------
# Builds a Jenkins image with required plugins pre-installed.
# Java is included in the jenkins/jenkins base image.
# No internet needed on target machine after this is built.

FROM jenkins/jenkins:lts

# Skip the setup wizard on first run
ENV JAVA_OPTS="-Djenkins.install.runSetupWizard=false"
ENV JENKINS_OPTS="--httpPort=8080"

# Switch to root to install system packages
USER root

# Install Python3, pip, git, docker CLI, and curl
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    git \
    curl \
    docker.io \
    && rm -rf /var/lib/apt/lists/*

# Install Python packages Jenkins will need to run the agent
RUN pip3 install --break-system-packages watchdog requests

# Switch back to Jenkins user
USER jenkins

# Pre-install required Jenkins plugins
RUN jenkins-plugin-cli --plugins \
    git \
    github \
    github-branch-source \
    workflow-aggregator \
    pipeline-stage-view \
    credentials \
    credentials-binding \
    plain-credentials

EXPOSE 8080

VOLUME /var/jenkins_home
