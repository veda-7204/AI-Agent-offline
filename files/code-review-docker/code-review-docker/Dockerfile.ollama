# Dockerfile.ollama
# ------------------
# Builds an Ollama image with Mistral model baked in.
# No internet needed on the target machine after this is built.

FROM ollama/ollama:latest

ENV OLLAMA_MODELS=/root/.ollama/models

# Start ollama in background, pull Mistral, then stop it
# Model files stay baked into the image layer
RUN /bin/bash -c "\
    ollama serve & \
    OLLAMA_PID=\$! && \
    echo 'Waiting for Ollama to start...' && \
    sleep 15 && \
    echo 'Pulling Mistral model...' && \
    ollama pull mistral && \
    echo 'Mistral pulled successfully.' && \
    kill \$OLLAMA_PID"

EXPOSE 11434

ENTRYPOINT ["/bin/ollama"]
CMD ["serve"]
